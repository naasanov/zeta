{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "detail": "Rebuild the daemon + plugin bundle (cached). Sandbox needs the bundle.",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "dependsOn": ["stop daemon"],
      "dependsOrder": "sequence"
    },
    {
      "label": "stop daemon",
      "detail": "Kill any stale task-run autopilotd so the debug launch can bind the socket (single-instance guard).",
      "type": "shell",
      "command": "pkill -f '[b]in/autopilotd' || true",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
