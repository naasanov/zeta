{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "daemon (debug)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/daemon/cmd/autopilotd",
      "cwd": "${workspaceFolder}",
      "args": ["-v"],
      "envFile": "${workspaceFolder}/sandbox/.env",
      "console": "integratedTerminal",
      "preLaunchTask": "build"
    },
    {
      "name": "sandbox: fresh zsh",
      "type": "node-terminal",
      "request": "launch",
      "command": "ZDOTDIR=${workspaceFolder}/sandbox exec zsh",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build"
    }
  ],
  "compounds": [
    {
      "name": "sandbox + daemon (debug)",
      "configurations": ["daemon (debug)", "sandbox: fresh zsh"],
      "stopAll": true
    }
  ]
}
