# Sandbox developer env — copy to sandbox/.env (gitignored) and fill in.
#
# Loaded automatically by:
#   - sandbox/.zshrc      (the interactive sandbox shell)
#   - the "daemon" VS Code task (so autopilotd sees GROQ_API_KEY)
#
# Plain KEY=value lines; they're sourced with `set -a`, so no `export` needed.

# Provider API keys. GROQ unset/empty → the daemon runs in echo mode. The
# anthropic/codestral keys are only needed if you select those profiles.
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

# Phase 2 config: point the daemon at a gitignored config.toml in this dir
# (copy config.toml.example), and pick which profile it runs. A profile named
# here that isn't in the config file is a startup error.
# ZSH_AUTOPILOT_CONFIG=/abs/path/to/zeta/sandbox/config.toml
# ZSH_AUTOPILOT_PROFILE=codestral

# Optional overrides applied on top of the selected profile.
# ZSH_AUTOPILOT_BASE_URL=https://api.groq.com/openai/v1
# ZSH_AUTOPILOT_MODEL=llama-3.3-70b-versatile
